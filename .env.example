# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_CHAT_ID=your_chat_id_here

# Qwen API (DashScope)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_TEXT_MODEL=qwen-plus

# 用户基础信息
USER_BMR=1916
USER_WEIGHT_GOAL=75.0
USER_PROTEIN_GOAL_PER_KG=1.8

# 定时任务时间（24h格式）
MORNING_CHECK_TIME=08:00
EVENING_SUMMARY_TIME=21:00
WEEKLY_REPORT_DAY=monday

# HealthKit 同步接口密钥（iOS 快捷指令 POST /hk/ingest 时校验）
HK_INGEST_TOKEN=generate_a_random_token_here

# 企业微信（可选，仅用 Telegram 可留空）
WECOM_PORT=5001
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_USER_ID=
